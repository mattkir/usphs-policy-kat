{
  "name": "@savoir/monorepo",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "USPHS Policy — knowledge agent with file-system search (@savoir monorepo)",
  "author": "HugoRCD",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattkir/usphs-policy-kat.git"
  },
  "bugs": {
    "url": "https://github.com/mattkir/usphs-policy-kat/issues"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "turbo run build --filter='./packages/*'",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:app": "turbo run dev --filter=@savoir/app",
    "dev:gateway": "curl -X GET http://localhost:3000/api/discord/gateway",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "automd": "automd",
    "workflow": "turbo run workflow:web --filter=@savoir/app"
  },
  "devDependencies": {
    "@hrcd/eslint-config": "^3.0.3",
    "automd": "^0.4.3",
    "playwright": "^1.58.2",
    "turbo": "^2.8.3"
  },
  "packageManager": "bun@1.2.22",
  "overrides": {
    "minimatch": "^10.0.1",
    "better-auth": "1.5.0",
    "@better-auth/core": "1.5.0",
    "@better-auth/api-key": "1.5.0"
  }
}
